{
  "name": "mobile-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "npx expo prebuild --platform android && npx expo run:android",
    "ios": "npx expo prebuild --platform ios && npx expo run:ios",
    "web": "expo start --web",
    "build:dev:native:ios": "eas build --profile development:simulator --platform ios",
    "build:dev:ios": "eas build --profile development --platform ios",
    "build:dev:android": "eas build --profile development --platform android",
    "build:preview:ios": "eas build --profile preview --platform ios",
    "build:preview:android": "eas build --profile preview --platform android",
    "build:prod:ios": "eas build --profile production --platform ios --clear-cache",
    "build:prod:android": "eas build --profile production --platform android --clear-cache",
    "build:clean": "eas build:clean"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/native": "^7.1.8",
    "axios": "^1.13.2",
    "babel-preset-expo": "~54.0.9",
    "date-fns": "^4.1.0",
    "expo": "~54.0.30",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.10",
    "expo-image": "~3.0.11",
    "expo-image-picker": "^17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-local-authentication": "^17.0.8",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.21",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "^15.0.10",
    "i18next": "^25.7.3",
    "react": "19.1.0",
    "react-i18next": "^16.5.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-google-mobile-ads": "^16.0.3",
    "react-native-iap": "^14.7.7",
    "react-native-nitro-modules": "^0.33.5",
    "react-native-paper": "^5.14.5",
    "react-native-paper-dates": "^0.22.51",
    "react-native-reanimated": "~4.1.1",
    "react-native-render-html": "^6.3.4",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-vector-icons": "^10.3.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "react-refresh": "^0.18.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "dotenv": "^17.2.3",
    "typescript": "~5.9.2"
  },
  "private": true
}
