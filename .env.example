# ============================================
# ESPORT NEWS - Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================

# ===================
# Server / Backend Go
# ===================
PORT=4000
ENV=production

# ===================
# Database (PostgreSQL)
# ===================
POSTGRES_USER=esportnews
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=esportnews
DATABASE_URL=postgres://esportnews:your-secure-password@db:5432/esportnews

# ===================
# Redis
# ===================
REDIS_URL=redis://redis:6379

# ===================
# JWT
# ===================
JWT_SECRET=your-jwt-secret-key

# ===================
# Frontend (Next.js)
# ===================
NEXT_PUBLIC_BACKEND_URL=http://backend:4000
NEXT_PUBLIC_API_URL=http://backend:4000/api
NEXTAUTH_SECRET=your-nextauth-secret
FRONTEND_URL=http://localhost:3002

# ===================
# Supabase (legacy)
# ===================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ===================
# APIs Externes
# ===================
PANDASCORE_API_KEY=your-pandascore-api-key

# ===================
# Stripe
# ===================
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_xxx
STRIPE_SECRET_KEY_LIVE=sk_live_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PRICE_ID=price_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ===================
# Email (Resend)
# ===================
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@yourdomain.com

# ===================
# Cloudflare
# ===================
CLOUDFLARE_TOKEN=your-cloudflare-token

# ===================
# Cloudflare R2 Storage
# ===================
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
CLOUDFLARE_R2_BUCKET_NAME=your-bucket-name
CLOUDFLARE_R2_ACCESS_KEY_ID=your-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-secret-access-key
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ===================
# Upload Configuration
# ===================
MAX_UPLOAD_SIZE=524288000
UPLOAD_TIMEOUT=600
