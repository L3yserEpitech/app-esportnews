# ============================================
# ESPORT NEWS - Environment Variables (CENTRALISÉ)
# ============================================
# ⚠️ IMPORTANT: Copier ce fichier vers .env et remplir avec vos vraies valeurs
# ⚠️ NE JAMAIS committer les fichiers .env* dans Git
#
# Ce fichier est la SOURCE UNIQUE pour toutes les variables d'environnement.
# Le backend Go, le frontend Next.js et l'app mobile chargent tous ce fichier
# depuis la racine du projet (via ../.env depuis leur sous-dossier).

# ===================
# Server / Backend Go
# ===================
PORT=4000
ENV=development
ENVIRONMENT=development
SERVER_PORT=4000
SERVER_HOST=0.0.0.0
LOG_LEVEL=debug

# ===================
# Database (PostgreSQL)
# ===================
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_64_CHARS
DB_NAME=esportnews
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_64_CHARS
POSTGRES_DB=esportnews
DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG_PASSWORD_64_CHARS@postgres:5432/esportnews?sslmode=disable

# ===================
# Redis
# ===================
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD_64_CHARS
REDIS_URL=redis://:CHANGE_ME_STRONG_PASSWORD_64_CHARS@redis:6379/0

# ===================
# JWT
# ===================
JWT_SECRET=CHANGE_ME_STRONG_SECRET_128_CHARS

# ===================
# Frontend (Next.js) - URLs LOCALES
# ===================
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXTAUTH_SECRET=CHANGE_ME_STRONG_SECRET_128_CHARS
NEXTAUTH_URL=http://localhost:3002
FRONTEND_URL=http://localhost:3002
CORS_ORIGINS=http://localhost:3002,http://localhost:3000,http://localhost:4000

# ===================
# Supabase (legacy)
# ===================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ===================
# APIs Externes
# ===================
# PANDASCORE_API_KEY and SPORTDEVS_API_KEY removed (replaced by LIQUIPEDIA_API_KEY)

# ===================
# Stripe
# ===================
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY_LIVE=sk_live_your_stripe_live_secret_key
STRIPE_SECRET_KEY=sk_test_your_stripe_test_secret_key
STRIPE_PRICE_ID=price_your_stripe_price_id
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ===================
# Email (Resend)
# ===================
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@yourdomain.com

# ===================
# Cloudflare
# ===================
CLOUDFLARE_TOKEN=your_cloudflare_token

# ===================
# Cloudflare R2 Storage
# ===================
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
CLOUDFLARE_R2_BUCKET_NAME=your-bucket-name
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# ===================
# Upload Configuration
# ===================
MAX_UPLOAD_SIZE=524288000
UPLOAD_TIMEOUT=600

# ===================
# Performance
# ===================
CACHE_TTL=3600
DB_MAX_CONNECTIONS=50

# ===================
# Liquipedia
# ===================
LIQUIPEDIA_API_KEY=your_liquipedia_api_key_here

# ===================
# Mobile App (Expo)
# ===================
EXPO_PUBLIC_ENVIRONMENT=development
EXPO_PUBLIC_API_URL=http://localhost:4000

# ===================
# AdMob
# ===================
ADMOB_IOS_APP_ID=ca-app-pub-xxxxx~xxxxx
ADMOB_ANDROID_APP_ID=ca-app-pub-xxxxx~xxxxx
ADMOB_INTERSTITIAL_ID=ca-app-pub-xxxxx/xxxxx
